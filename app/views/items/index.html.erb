<% content_for :title, "Items" %>

<div class="flex-between mb-3">
  <h1>Items</h1>
  <%= link_to "New Item", new_item_path, class: "btn" %>
</div>

<div class="filter-panel">
  <%= form_with url: items_path, method: :get, local: true do %>
    <div class="filter-row">
      <div class="filter-group" style="flex: 2 1 260px;">
        <label for="query">Search</label>
        <%= text_field_tag :query, params[:query], placeholder: "Search items...", id: "query" %>
      </div>

      <div class="filter-group">
        <label>Community</label>
        <%= select_tag :community,
            options_for_select(
              [["All", ""], *Item::COMMUNITY_NAMES.map { |k, v| [v, k] }],
              params[:community]
            ) %>
      </div>

      <div class="filter-group">
        <label>Min price</label>
        <%= number_field_tag :min_price, params[:min_price].presence, placeholder: "$0" %>
      </div>

      <div class="filter-group">
        <label>Max price</label>
        <%= number_field_tag :max_price, params[:max_price].presence, placeholder: "No limit" %>
      </div>
    </div>

    <div class="checkbox-group mt-2">
      <strong>Status:</strong>
      <% ["available", "reserved", "sold"].each do |s| %>
        <label>
          <%= check_box_tag "status[]", s, params[:status].nil? || params[:status].include?(s) %>
          <%= s.capitalize %>
        </label>
      <% end %>
    </div>

    <div class="mt-2">
      <%= submit_tag "Apply Filters" %>
    </div>
  <% end %>
</div>

<div id="items" class="items-grid">
  <% @items.each do |item| %>
    <div class="card item-card">
      <div class="flex-between">
        <h3 class="item-title"><%= link_to item.title, item %></h3>
        <span class="item-price">$<%= item.price %></span>
      </div>
      <p class="item-desc"><%= item.description %></p>
      <div class="item-meta">
        <span class="badge badge-<%= item.status %>"><%= item.status.capitalize %></span>
        <span><%= item.community_name %></span>
      </div>
    </div>
  <% end %>
</div>
