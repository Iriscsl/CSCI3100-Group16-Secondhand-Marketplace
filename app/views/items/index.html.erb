<p style="color: green"><%= notice %></p>

<% content_for :title, "Items" %>

<h1>Items</h1>

<%= form_with url: items_path, method: :get, local: true do %>
  <div>
    <strong>Filter by status:</strong><br>

    <% ["available", "reserved", "sold"].each do |s| %>
      <%= check_box_tag "status[]", s, params[:status].nil? || params[:status].include?(s) %>
      <%= label_tag s, s.capitalize %><br>
    <% end %>
  </div>

  <div>
    <strong><%= label_tag :community, "Filter by community" %></strong>
    <%= select_tag :community,
        options_for_select(
          [["All", ""], *Item::COMMUNITY_NAMES.map { |k, v| [v, k] }],
          params[:community]
        ) %>
  </div>

  <div>
    <strong>Filter by price range:</strong><br>
    <%= label_tag :min_price, "Min price" %>
    <%= number_field_tag :min_price, params[:min_price].presence %>
  </div>

  <div>
    <%= label_tag :max_price, "Max price" %>
    <%= number_field_tag :max_price, params[:max_price].presence %>
  </div>

  <%= submit_tag "Filter" %>
<% end %>

<hr>

<div id="items">
  <% @items.each do |item| %>
    <%= render item %>
    <p>
      <%= link_to "Show this item", item %>
    </p>
  <% end %>
</div>

<%= link_to "New item", new_item_path %>
