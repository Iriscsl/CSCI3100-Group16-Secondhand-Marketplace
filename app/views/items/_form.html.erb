<%= form_with(model: item) do |form| %>
  <% if item.errors.any? %>
    <div style="background: #f8d7da; color: #721c24; padding: 14px 18px; border-radius: 8px; margin-bottom: 20px;">
      <strong><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</strong>
      <ul style="margin: 8px 0 0; padding-left: 20px;">
        <% item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.textarea :description %>
  </div>

  <div class="field">
    <%= form.label :price %>
    <%= form.number_field :price %>
  </div>

  <div class="field">
    <%= form.label :status %>
    <%= form.select :status, Item.statuses.keys.map { |s| [s.to_s.humanize, s] } %>
  </div>

  <div class="field">
    <%= form.label :community %>
    <%= form.select :community, Item.communities.map { |key, value| [Item::COMMUNITY_NAMES[key.to_sym], value] } %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
