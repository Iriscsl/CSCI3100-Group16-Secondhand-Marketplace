<div class="card" style="max-width: 720px;">
  <div class="detail-header">
    <div>
      <h1><%= @item.title %></h1>
      <span class="badge badge-<%= @item.status %>"><%= @item.status.capitalize %></span>
    </div>
    <span class="item-price" style="font-size: 1.6rem;">$<%= @item.price %> <small class="text-muted" style="font-size: 14px;">HKD</small></span>
  </div>

  <div class="detail-field">
    <strong>Description</strong>
    <span><%= @item.description %></span>
  </div>

  <div class="detail-field">
    <strong>Community</strong>
    <span><%= @item.community_name %></span>
  </div>

  <div class="detail-actions">
    <% if user_signed_in? && @item.user == current_user %>
      <%= button_to "Delete", @item, method: :delete, class: "btn btn-danger" %>
    <% end %>

    <% if @item.available? && user_signed_in? && @item.user != current_user %>
      <%= button_to "Buy Now — $#{@item.price} HKD", checkout_path(item_id: @item.id),
          method: :post,
          data: { turbo: false },
          class: "btn",
          style: "background-color: #6772e5;" %>
    <% end %>

    <% if user_signed_in? && @item.user == current_user %>
      <% if @item.available? %>
        <%= button_to "Mark as Reserved", update_status_item_path(@item, status: :reserved), method: :patch, class: "btn btn-warning" %>
      <% elsif @item.reserved? %>
        <%= button_to "Mark as Sold", update_status_item_path(@item, status: :sold), method: :patch, class: "btn btn-success" %>
      <% end %>
    <% end %>

    <% if user_signed_in? && current_user != @item.user %>
      <%= button_to "Message Seller",
          conversations_path(
            item_id: @item.id,
            seller_id: @item.user
          ),
          method: :post, class: "btn" %>
    <% end %>
  </div>
</div>

<div class="detail-actions mt-2">
  <%= link_to "Back to Items", items_path, class: "btn btn-outline" %>
  <% if user_signed_in? && @item.user == current_user %>
    <%= link_to "Edit", edit_item_path(@item), class: "btn btn-outline" %>
  <% end %>
</div>
