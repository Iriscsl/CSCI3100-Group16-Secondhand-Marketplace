<!-- Email wrapper -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; margin: 0; padding: 0;">
  <tr>
    <td align="center" style="padding: 40px 16px;">
      <!-- Main card -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 12px; overflow: hidden;">

        <!-- Header with solid color (gradient not supported in most email clients) -->
        <tr>
          <td style="background-color: #2c3e50; padding: 0;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="padding: 32px 40px 24px; text-align: center;">
                  <p style="margin: 0 0 4px; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: #85929e;">Daily Digest</p>
                  <h1 style="margin: 0; color: #ffffff; font-size: 26px; font-weight: 700; letter-spacing: -0.5px;">CUHK Marketplace</h1>
                  <p style="margin: 12px 0 0; color: #aeb6bf; font-size: 14px;"><%= Date.current.strftime('%A, %B %d, %Y') %></p>
                </td>
              </tr>
              <!-- Accent bar -->
              <tr>
                <td style="background-color: #3498db; height: 4px; font-size: 0; line-height: 0;">&nbsp;</td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Greeting + Summary -->
        <tr>
          <td style="padding: 32px 40px 8px;">
            <p style="margin: 0; font-size: 17px; color: #2c3e50; line-height: 1.5;">
              Hi <strong><%= @user.name || @user.email %></strong>,
            </p>
            <p style="margin: 12px 0 0; font-size: 15px; color: #5d6d7e; line-height: 1.6;">
              <% if @new_items.size == 1 %>
                There is <strong style="color: #2c3e50;">1 new listing</strong> on the marketplace today.
              <% else %>
                There are <strong style="color: #2c3e50;"><%= @new_items.size %> new listings</strong> on the marketplace today.
              <% end %>
            </p>
          </td>
        </tr>

        <!-- Divider -->
        <tr>
          <td style="padding: 16px 40px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr><td style="border-bottom: 1px solid #ebedef; font-size: 0; line-height: 0; height: 1px;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>

        <!-- Item cards -->
        <tr>
          <td style="padding: 8px 40px 24px;">
            <% @new_items.each do |item| %>
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 16px;">
                <tr>
                  <!-- Left accent bar -->
                  <td width="4" style="background-color: <%= item.available? ? '#27ae60' : '#f39c12' %>; border-radius: 4px 0 0 4px;"></td>
                  <!-- Card content -->
                  <td style="background-color: #fafbfc; border: 1px solid #ebedef; border-left: none; border-radius: 0 8px 8px 0; padding: 18px 20px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="vertical-align: top;">
                          <a href="<%= item_url(item) %>" style="font-size: 17px; font-weight: 700; color: #2c3e50; text-decoration: none; line-height: 1.3;">
                            <%= item.title %>
                          </a>
                          <p style="margin: 6px 0 12px; font-size: 14px; color: #7f8c8d; line-height: 1.5;">
                            <%= truncate(item.description, length: 100) %>
                          </p>
                          <table cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td style="font-size: 12px; color: #95a5a6; padding-right: 20px; white-space: nowrap;">
                                <span style="color: #3498db;">&#9679;</span>&nbsp; <%= item.community_name %>
                              </td>
                              <td style="font-size: 12px; color: #95a5a6; white-space: nowrap;">
                                <span style="color: #3498db;">&#9679;</span>&nbsp; <%= item.user.name || item.user.email %>
                              </td>
                            </tr>
                          </table>
                        </td>
                        <td width="110" style="vertical-align: top; text-align: right; padding-left: 16px;">
                          <span style="font-size: 22px; font-weight: 800; color: #27ae60; white-space: nowrap;">HK$<%= item.price %></span>
                          <br>
                          <table cellpadding="0" cellspacing="0" border="0" align="right" style="margin-top: 8px;">
                            <tr>
                              <td style="font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 12px; background-color: <%= item.available? ? '#e8f8f0' : '#fef9e7' %>; color: <%= item.available? ? '#1e8449' : '#9a7d0a' %>; text-align: center;">
                                <%= item.status.capitalize %>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            <% end %>
          </td>
        </tr>

        <!-- CTA Button -->
        <tr>
          <td align="center" style="padding: 8px 40px 36px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td align="center" style="background-color: #2c3e50; border-radius: 8px;">
                  <a href="<%= items_url %>" style="display: inline-block; color: #ffffff; padding: 14px 40px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.3px;">
                    Browse All Items &rarr;
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background-color: #f8f9fa; padding: 24px 40px; border-top: 1px solid #ebedef;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td align="center">
                  <p style="margin: 0 0 8px; font-size: 13px; font-weight: 600; color: #7f8c8d;">CUHK Secondhand Marketplace</p>
                  <p style="margin: 0; font-size: 12px; color: #adb5bd; line-height: 1.6;">
                    You received this email because you are a registered user.
                    <br>
                    &copy; <%= Date.current.year %> CUHK Marketplace. All rights reserved.
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
