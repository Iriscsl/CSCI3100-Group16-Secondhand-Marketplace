<h1>Your Chats</h1>

<% if @conversations.any? %>
  <ul class="conversation-list">
    <% @conversations.each do |conversation| %>
      <% other_user =
           conversation.buyer == current_user ?
             conversation.seller :
             conversation.buyer %>

      <li>
        <div>
          <%= link_to conversation.item.title, conversation_path(conversation) %>
          <span class="text-muted"> with <%= other_user.name %></span>
        </div>
        <span class="conversation-count"><%= conversation.messages.count %> messages</span>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="card text-center" style="padding: 40px;">
    <p class="text-muted">You have no conversations yet.</p>
    <%= link_to "Browse Items", items_path, class: "btn" %>
  </div>
<% end %>