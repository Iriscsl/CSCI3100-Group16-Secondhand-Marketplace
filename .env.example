# === Supabase PostgreSQL (use Session mode pooler from Supabase Dashboard) ===
DATABASE_HOST=aws-0-YOUR-REGION.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USERNAME=postgres.YOUR_PROJECT_REF
DATABASE_PASSWORD=your_supabase_db_password
DATABASE_SSLMODE=require
DATABASE_PREPARED_STATEMENTS=false

# === Email (Gmail) ===
GMAIL_USERNAME=your_email@gmail.com
GMAIL_APP_PASSWORD=your_password_here

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX